<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.AiModelConfigMapper">
    
    <resultMap type="AiModelConfig" id="AiModelConfigResult">
        <result property="modelId"    column="model_id"    />
        <result property="modelName"    column="model_name"    />
        <result property="modelType"    column="model_type"    />
        <result property="apiUrl"    column="api_url"    />
        <result property="apiKey"    column="api_key"    />
        <result property="modelVersion"    column="model_version"    />
        <result property="maxTokens"    column="max_tokens"    />
        <result property="temperature"    column="temperature"    />
        <result property="isDefault"    column="is_default"    />
        <result property="status"    column="status"    />
        <result property="supportTemperature"    column="support_temperature"    />
        <result property="remark"    column="remark"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectAiModelConfigVo">
        select model_id, model_name, model_type, api_url, api_key, model_version, max_tokens, temperature, is_default, status, support_temperature, remark, create_by, create_time, update_by, update_time from ai_model_config
    </sql>

    <select id="selectAiModelConfigList" parameterType="AiModelConfig" resultMap="AiModelConfigResult">
        <include refid="selectAiModelConfigVo"/>
        <where>  
            <if test="modelName != null  and modelName != ''"> and model_name like concat('%', #{modelName}, '%')</if>
            <if test="modelType != null  and modelType != ''"> and model_type = #{modelType}</if>
            <if test="isDefault != null  and isDefault != ''"> and is_default = #{isDefault}</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
        </where>
        order by is_default desc, create_time desc
    </select>
    
    <select id="selectAiModelConfigByModelId" parameterType="Long" resultMap="AiModelConfigResult">
        <include refid="selectAiModelConfigVo"/>
        where model_id = #{modelId}
    </select>

    <select id="selectDefaultModelConfig" parameterType="String" resultMap="AiModelConfigResult">
        <include refid="selectAiModelConfigVo"/>
        where status = '0' and is_default = '1'
        <if test="modelType != null and modelType != ''">
            and model_type = #{modelType}
        </if>
        order by create_time desc
        limit 1
    </select>
        
    <insert id="insertAiModelConfig" parameterType="AiModelConfig" useGeneratedKeys="true" keyProperty="modelId">
        insert into ai_model_config
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="modelName != null and modelName != ''">model_name,</if>
            <if test="modelType != null and modelType != ''">model_type,</if>
            <if test="apiUrl != null and apiUrl != ''">api_url,</if>
            <if test="apiKey != null">api_key,</if>
            <if test="modelVersion != null">model_version,</if>
            <if test="maxTokens != null">max_tokens,</if>
            <if test="temperature != null">temperature,</if>
            <if test="isDefault != null">is_default,</if>
            <if test="status != null">status,</if>
            <if test="supportTemperature != null">support_temperature,</if>
            <if test="remark != null">remark,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="modelName != null and modelName != ''">#{modelName},</if>
            <if test="modelType != null and modelType != ''">#{modelType},</if>
            <if test="apiUrl != null and apiUrl != ''">#{apiUrl},</if>
            <if test="apiKey != null">#{apiKey},</if>
            <if test="modelVersion != null">#{modelVersion},</if>
            <if test="maxTokens != null">#{maxTokens},</if>
            <if test="temperature != null">#{temperature},</if>
            <if test="isDefault != null">#{isDefault},</if>
            <if test="status != null">#{status},</if>
            <if test="supportTemperature != null">#{supportTemperature},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
         </trim>
    </insert>

    <update id="updateAiModelConfig" parameterType="AiModelConfig">
        update ai_model_config
        <trim prefix="SET" suffixOverrides=",">
            <if test="modelName != null and modelName != ''">model_name = #{modelName},</if>
            <if test="modelType != null and modelType != ''">model_type = #{modelType},</if>
            <if test="apiUrl != null and apiUrl != ''">api_url = #{apiUrl},</if>
            <if test="apiKey != null">api_key = #{apiKey},</if>
            <if test="modelVersion != null">model_version = #{modelVersion},</if>
            <if test="maxTokens != null">max_tokens = #{maxTokens},</if>
            <if test="temperature != null">temperature = #{temperature},</if>
            <if test="isDefault != null">is_default = #{isDefault},</if>
            <if test="status != null">status = #{status},</if>
            <if test="supportTemperature != null">support_temperature = #{supportTemperature},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where model_id = #{modelId}
    </update>

    <delete id="deleteAiModelConfigByModelId" parameterType="Long">
        delete from ai_model_config where model_id = #{modelId}
    </delete>

    <delete id="deleteAiModelConfigByModelIds" parameterType="String">
        delete from ai_model_config where model_id in 
        <foreach item="modelId" collection="array" open="(" separator="," close=")">
            #{modelId}
        </foreach>
    </delete>

    <update id="cancelOtherDefault" parameterType="String">
        update ai_model_config set is_default = '0'
        where is_default = '1'
        <if test="modelType != null and modelType != ''">
            and model_type = #{modelType}
        </if>
    </update>
</mapper>
