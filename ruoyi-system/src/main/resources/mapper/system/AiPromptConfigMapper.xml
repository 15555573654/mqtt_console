<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.AiPromptConfigMapper">
    
    <resultMap type="AiPromptConfig" id="AiPromptConfigResult">
        <result property="configId"    column="config_id"    />
        <result property="configName"    column="config_name"    />
        <result property="promptContent"    column="prompt_content"    />
        <result property="aiModel"    column="ai_model"    />
        <result property="isDefault"    column="is_default"    />
        <result property="status"    column="status"    />
        <result property="remark"    column="remark"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectAiPromptConfigVo">
        select config_id, config_name, prompt_content, ai_model, is_default, status, remark, create_by, create_time, update_by, update_time from ai_prompt_config
    </sql>

    <select id="selectAiPromptConfigList" parameterType="AiPromptConfig" resultMap="AiPromptConfigResult">
        <include refid="selectAiPromptConfigVo"/>
        <where>  
            <if test="configName != null  and configName != ''"> and config_name like concat('%', #{configName}, '%')</if>
            <if test="aiModel != null  and aiModel != ''"> and ai_model = #{aiModel}</if>
            <if test="isDefault != null  and isDefault != ''"> and is_default = #{isDefault}</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
        </where>
        order by is_default desc, create_time desc
    </select>
    
    <select id="selectAiPromptConfigByConfigId" parameterType="Long" resultMap="AiPromptConfigResult">
        <include refid="selectAiPromptConfigVo"/>
        where config_id = #{configId}
    </select>

    <select id="selectDefaultPromptConfig" parameterType="String" resultMap="AiPromptConfigResult">
        <include refid="selectAiPromptConfigVo"/>
        where status = '0' and is_default = '1'
        <if test="aiModel != null and aiModel != ''">
            and (ai_model = #{aiModel} or ai_model is null)
        </if>
        order by 
            case when ai_model = #{aiModel} then 1 else 2 end,
            create_time desc
        limit 1
    </select>
        
    <insert id="insertAiPromptConfig" parameterType="AiPromptConfig" useGeneratedKeys="true" keyProperty="configId">
        insert into ai_prompt_config
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="configName != null and configName != ''">config_name,</if>
            <if test="promptContent != null and promptContent != ''">prompt_content,</if>
            <if test="aiModel != null">ai_model,</if>
            <if test="isDefault != null">is_default,</if>
            <if test="status != null">status,</if>
            <if test="remark != null">remark,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="configName != null and configName != ''">#{configName},</if>
            <if test="promptContent != null and promptContent != ''">#{promptContent},</if>
            <if test="aiModel != null">#{aiModel},</if>
            <if test="isDefault != null">#{isDefault},</if>
            <if test="status != null">#{status},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
         </trim>
    </insert>

    <update id="updateAiPromptConfig" parameterType="AiPromptConfig">
        update ai_prompt_config
        <trim prefix="SET" suffixOverrides=",">
            <if test="configName != null and configName != ''">config_name = #{configName},</if>
            <if test="promptContent != null and promptContent != ''">prompt_content = #{promptContent},</if>
            <if test="aiModel != null">ai_model = #{aiModel},</if>
            <if test="isDefault != null">is_default = #{isDefault},</if>
            <if test="status != null">status = #{status},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where config_id = #{configId}
    </update>

    <delete id="deleteAiPromptConfigByConfigId" parameterType="Long">
        delete from ai_prompt_config where config_id = #{configId}
    </delete>

    <delete id="deleteAiPromptConfigByConfigIds" parameterType="String">
        delete from ai_prompt_config where config_id in 
        <foreach item="configId" collection="array" open="(" separator="," close=")">
            #{configId}
        </foreach>
    </delete>

    <update id="cancelOtherDefault" parameterType="String">
        update ai_prompt_config set is_default = '0'
        where is_default = '1'
        <if test="aiModel != null and aiModel != ''">
            and (ai_model = #{aiModel} or ai_model is null)
        </if>
    </update>
</mapper>
