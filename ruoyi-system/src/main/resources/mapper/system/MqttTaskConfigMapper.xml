<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.MqttTaskConfigMapper">
    
    <resultMap type="MqttTaskConfig" id="MqttTaskConfigResult">
        <result property="configId"       column="config_id"       />
        <result property="configName"     column="config_name"     />
        <result property="configContent"  column="config_content"  />
        <result property="username"       column="username"        />
        <result property="createBy"       column="create_by"       />
        <result property="createTime"     column="create_time"     />
        <result property="updateBy"       column="update_by"       />
        <result property="updateTime"     column="update_time"     />
        <result property="remark"         column="remark"          />
    </resultMap>

    <sql id="selectMqttTaskConfigVo">
        select config_id, config_name, config_content, username, create_by, create_time, update_by, update_time, remark from mqtt_task_config
    </sql>

    <select id="selectMqttTaskConfigList" parameterType="MqttTaskConfig" resultMap="MqttTaskConfigResult">
        <include refid="selectMqttTaskConfigVo"/>
        <where>  
            <if test="configName != null  and configName != ''"> and config_name like concat('%', #{configName}, '%')</if>
            <if test="username != null  and username != ''"> and username = #{username}</if>
        </where>
        order by create_time desc
    </select>
    
    <select id="selectMqttTaskConfigByConfigId" parameterType="Long" resultMap="MqttTaskConfigResult">
        <include refid="selectMqttTaskConfigVo"/>
        where config_id = #{configId}
    </select>
        
    <insert id="insertMqttTaskConfig" parameterType="MqttTaskConfig" useGeneratedKeys="true" keyProperty="configId">
        insert into mqtt_task_config
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="configName != null and configName != ''">config_name,</if>
            <if test="configContent != null and configContent != ''">config_content,</if>
            <if test="username != null and username != ''">username,</if>
            <if test="createBy != null">create_by,</if>
            <if test="remark != null">remark,</if>
            create_time
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="configName != null and configName != ''">#{configName},</if>
            <if test="configContent != null and configContent != ''">#{configContent},</if>
            <if test="username != null and username != ''">#{username},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="remark != null">#{remark},</if>
            sysdate()
         </trim>
    </insert>

    <update id="updateMqttTaskConfig" parameterType="MqttTaskConfig">
        update mqtt_task_config
        <trim prefix="SET" suffixOverrides=",">
            <if test="configName != null and configName != ''">config_name = #{configName},</if>
            <if test="configContent != null and configContent != ''">config_content = #{configContent},</if>
            <if test="username != null and username != ''">username = #{username},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </trim>
        where config_id = #{configId}
    </update>

    <delete id="deleteMqttTaskConfigByConfigId" parameterType="Long">
        delete from mqtt_task_config where config_id = #{configId}
    </delete>

    <delete id="deleteMqttTaskConfigByConfigIds" parameterType="String">
        delete from mqtt_task_config where config_id in 
        <foreach item="configId" collection="array" open="(" separator="," close=")">
            #{configId}
        </foreach>
    </delete>
</mapper>
